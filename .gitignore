# ==========================================
# 1. Environment & Sensitive Data (CRITICAL)
# ==========================================
# Block actual runtime secrets, credentials, and tokens
.env
.env.*
!.env.default
!.env.example

# ==========================================
# 2. Local Container & Runtime Data
# ==========================================
# Block local database files, logs, and cache if using bind mounts
**/postgres/
**/db-data/
*.log
.docker/

# ==========================================
# 3. OS & IDE Specific Files
# ==========================================
# macOS system files
.DS_Store
.AppleDouble
.LSOverride

# Editor configurations (Allowing shared team settings is optional)
.vscode/
.idea/
*.suo
*.user

# ==========================================
# 4. Local App Build Artifacts
# ==========================================
# Prevents host-compiled artifacts from bleeding into the infra repo
**/node_modules/
**/bin/
**/obj/
